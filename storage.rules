rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // ── Helper ──────────────────────────────────────────────────────────────

    function isAuthenticated() {
      return request.auth != null;
    }

    function isImage() {
      return request.resource.contentType.matches('image/.*');
    }

    function isUnder5MB() {
      return request.resource.size < 5 * 1024 * 1024;
    }

    function isUnder10MB() {
      return request.resource.size < 10 * 1024 * 1024;
    }

    // ── User photo submissions ───────────────────────────────────────────────
    // Path: challenge_photos/{userId}/{photoId}

    match /challenge_photos/{userId}/{photoId} {
      allow read: if isAuthenticated();
      allow write: if request.auth.uid == userId
        && isImage()
        && isUnder5MB();
    }

    // Path: photo_submissions/{userId}/{filename}
    // Used by ChallengeService.uploadPhoto() in the Flutter app

    match /photo_submissions/{userId}/{filename} {
      allow read: if isAuthenticated();
      allow write: if request.auth.uid == userId
        && isImage()
        && isUnder5MB();
    }

    // ── Admin-uploaded level content images ──────────────────────────────────
    // Path: level_images/{levelId}/{filename}
    // Written by admin panel (levelService.uploadImage); read by all authenticated users.

    match /level_images/{levelId}/{filename} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated()
        && isImage()
        && isUnder10MB();
      // Note: enforce admin-only writes via Firestore rules + App Check.
      // Storage rules cannot query Firestore for role checks without significant latency.
    }

    // ── Admin-uploaded pretest / quiz images ─────────────────────────────────
    // Path: pretest_images/{filename}

    match /pretest_images/{filename} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated()
        && isImage()
        && isUnder10MB();
    }

    // ── Catch-all: deny everything else ──────────────────────────────────────

    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
